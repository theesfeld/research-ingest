{
  "manifest_version": 3,
  "name": "Send to Grok Research",
  "version": "0.1.0",
  "description": "Send page, selection, image, or link into the local research-ingest vault.",
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "nativeMessaging",
    "scripting",
    "notifications"
  ],
  "host_permissions": ["<all_urls>", "http://127.0.0.1:18765/*", "http://localhost:18765/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Send to Grok Research",
    "default_popup": "popup.html"
  },
  "commands": {
    "send-selection-or-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Send selection or full page to Grok Research"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
